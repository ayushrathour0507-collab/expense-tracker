# Copy to .env and fill in real values. Never commit .env.

# Supabase: Project Settings → Database → Connection string → URI
# Use the "Session mode" or "Direct connection" URI, then change the scheme:
#   postgresql://...  →  postgresql+psycopg://...
# If the password has @ # % etc., URL-encode it.
#
# Example (direct):
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require
#
# Example (pooler / PgBouncer — use if Supabase recommends it for your client):
# DATABASE_URL=postgresql+psycopg://postgres.xxxxx:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

DATABASE_URL=

# Long random string for signing JWTs (e.g. openssl rand -hex 32)
JWT_SECRET=

# Comma-separated list of allowed CORS origins (e.g., your Vercel frontend URL)
# For development: http://localhost:5173,http://127.0.0.1:5173
# For production: https://your-vercel-app.vercel.app
ALLOWED_ORIGINS=
